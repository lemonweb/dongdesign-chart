{
  "color": [
    "#3365F7",
    "#30CAFA",
    "#0B2165",
    "#EF69CA",
    "#FFBA30",
    "#16C87F",
    "#482AC4",
    "#FF6D4E",
    "#B8CE92",
    "#004B91",
    "#008FCA",
    "#D1DEF3"
  ],
  "backgroundColor": "rgba(0,0,0,0)",
  "textStyle": {
    "fontFamily": "PingFang SC, Roboto, 'Microsoft YaHei', sans-serif"
  },
  "title": {
    "textStyle": { "color": "#1C1D1F", "fontSize": 16, "fontWeight": 600 },
    "subtextStyle": { "color": "#8C8D91", "fontSize": 12 }
  },
  "line": {
    "smooth": true,
    "symbol": "circle",
    "symbolSize": 0,
    "lineStyle": { "width": 2 },
    "emphasis": { "scale": true }
  },
  "bar": {
    "itemStyle": { "barBorderRadius": [4, 4, 0, 0] },
    "barMaxWidth": 32
  },
  "pie": {
    "itemStyle": { "borderColor": "#FFFFFF", "borderWidth": 1 },
    "label": { "color": "#515357", "fontSize": 12 }
  },
  "radar": {
    "splitLine": { "lineStyle": { "color": ["#E6E7EB"] } },
    "splitArea": { "areaStyle": { "color": ["rgba(247,248,250,0.5)", "rgba(255,255,255,0)"] } },
    "axisLine": { "lineStyle": { "color": "#E6E7EB" } },
    "name": { "color": "#515357" }
  },
  "categoryAxis": {
    "axisLine": { "show": true, "lineStyle": { "color": "#E6E7EB" } },
    "axisTick": { "show": false },
    "axisLabel": { "show": true, "color": "#8C8C8C", "fontSize": 12 },
    "splitLine": { "show": false, "lineStyle": { "color": ["#F0F0F0"] } },
    "splitArea": { "show": false }
  },
  "valueAxis": {
    "axisLine": { "show": false },
    "axisTick": { "show": false },
    "axisLabel": { "color": "#8C8C8C", "fontSize": 12 },
    "splitLine": { "show": true, "lineStyle": { "color": ["#F0F0F0"] } },
    "splitArea": { "show": false }
  },
  "logAxis": {
    "axisLabel": { "color": "#8C8C8C", "fontSize": 12 },
    "splitLine": { "lineStyle": { "color": ["#F0F0F0"] } }
  },
  "timeAxis": {
    "axisLine": { "lineStyle": { "color": "#E6E7EB" } },
    "axisLabel": { "color": "#8C8C8C", "fontSize": 12 },
    "splitLine": { "show": false }
  },
  "legend": {
    "textStyle": { "color": "#515357", "fontSize": 12 },
    "icon": "roundRect",
    "itemWidth": 14,
    "itemHeight": 8,
    "itemGap": 20
  },
  "tooltip": {
    "backgroundColor": "#1C1D1F",
    "borderWidth": 0,
    "borderRadius": 6,
    "padding": [8, 12],
    "textStyle": { "color": "#FFFFFF", "fontSize": 12 },
    "axisPointer": {
      "lineStyle": { "color": "#DCDDE0", "width": 1 },
      "crossStyle": { "color": "#DCDDE0", "width": 1 },
      "shadowStyle": { "color": "rgba(55,101,247,0.06)" }
    }
  },
  "grid": {
    "left": 8,
    "right": 8,
    "top": 32,
    "bottom": 8,
    "containLabel": true
  }
}
