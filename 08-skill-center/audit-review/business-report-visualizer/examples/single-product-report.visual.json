  "layout": {
    "type": "responsive_bento",
    "columns": 12,
    "gap": 16,
    "sections": [
      { "id": "header_slot", "component_id": "report_header", "span": 12, "height": "compact", "priority": 1 },
      { "id": "summary_slot", "component_id": "insight_summary", "span": 12, "height": "large", "priority": 2 },
      { "id": "kpi_slot", "component_id": "kpi_group", "span": 12, "height": "medium", "priority": 3 },
      { "id": "trend_slot", "component_id": "trend_chart", "span": 8, "height": "large", "priority": 4 },
      { "id": "channel_slot", "component_id": "channel_rank", "span": 4, "height": "large", "priority": 5 },
      { "id": "action_slot", "component_id": "action_plan", "span": 12, "height": "large", "priority": 6 }
    ]
  },
  "qa": {
    "data_consistency": "pass",
    "chart_selection": "pass",
    "evidence_chain": "pass",
